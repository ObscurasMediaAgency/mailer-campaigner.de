# Obscuras Mailer Campaigner - Downloads Directory
# Prevent directory listing and direct access to JSON files

Options -Indexes

# Deny access to JSON files (should be accessed via API)
<FilesMatch "\.(json)$">
    Require all denied
</FilesMatch>

# Allow ZIP and checksum files
<FilesMatch "\.(zip|sha256|asc)$">
    Require all granted
</FilesMatch>
