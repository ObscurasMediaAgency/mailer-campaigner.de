# Mailer Campaigner API - Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle die Werte aus
# WICHTIG: .env niemals in Git committen!

# ═══════════════════════════════════════════════════════════════════════════
# UMGEBUNG
# ═══════════════════════════════════════════════════════════════════════════
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mailer-campaigner.de

# ═══════════════════════════════════════════════════════════════════════════
# SMTP KONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
SMTP_HOST=mail.dein-server.de
SMTP_PORT=465
SMTP_USERNAME=noreply@mailer-campaigner.de
SMTP_PASSWORD=
SMTP_ENCRYPTION=ssl

EMAIL_FROM=noreply@mailer-campaigner.de
EMAIL_FROM_NAME="Mailer Campaigner"

# ═══════════════════════════════════════════════════════════════════════════
# STRIPE KONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Secret Key (sk_test_... oder sk_live_...)
STRIPE_SECRET_KEY=

# Publishable Key (pk_test_... oder pk_live_...)
STRIPE_PUBLISHABLE_KEY=

# Webhook Secret (whsec_...)
STRIPE_WEBHOOK_SECRET=

# Optional: Feste Price-ID aus Stripe Dashboard
STRIPE_PRICE_ID=

# ═══════════════════════════════════════════════════════════════════════════
# PRODUKT KONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
PRODUCT_NAME="Mailer Campaigner Pro"
PRODUCT_PRICE_EUR=129.00
LICENSE_VALIDITY_DAYS=365

# ═══════════════════════════════════════════════════════════════════════════
# SICHERHEIT
# ═══════════════════════════════════════════════════════════════════════════
# Komma-separierte Liste erlaubter Origins
ALLOWED_ORIGINS=https://mailer-campaigner.de,https://www.mailer-campaigner.de

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
