{
    "name": "obscuras/mailer-campaigner-api",
    "description": "API für Mailer Campaigner - Newsletter & Lizenz-Management",
    "version": "1.0.0",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "Obscuras Media Agency",
            "email": "dev@mailer-campaigner.de"
        }
    ],
    "require": {
        "php": ">=8.0",
        "stripe/stripe-php": "^14.0",
        "phpmailer/phpmailer": "^6.9",
        "symfony/dotenv": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "MailerCampaigner\\": "includes/"
        }
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('data') || mkdir('data', 0755);\"",
            "@php -r \"file_exists('logs') || mkdir('logs', 0755);\""
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
